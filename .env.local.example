# forum-api: use host.docker.internal (Docker cannot resolve *.forum.test)
# forum-app: use http://supabase.forum.test (browser resolves via /etc/hosts)

PORT=3001
CORS_ORIGIN=http://app.forum.test,http://localhost:3000,http://127.0.0.1:3000

SUPABASE_URL=http://host.docker.internal:54321
SUPABASE_SERVICE_ROLE_KEY=

DB_HOST=host.docker.internal
# forum db:migrate uses 127.0.0.1 on the host (Supabase Postgres port 54322)
DB_PORT=54322
DB_NAME=postgres
DB_USERNAME=postgres
DB_PASSWORD=postgres
