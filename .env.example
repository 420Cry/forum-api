PORT=3001
# forum-server: http://app.forum.test
# local dev: http://localhost:3000
CORS_ORIGIN=http://app.forum.test,http://localhost:3000

# Supabase Auth - server-side token verification
# Run `forum db:status` and copy values into .env
SUPABASE_URL=http://supabase.forum.test
SUPABASE_SERVICE_ROLE_KEY=

# Supabase local Postgres (defaults match `supabase start`)
DB_HOST=127.0.0.1
DB_PORT=54322
DB_NAME=postgres
DB_USERNAME=postgres
DB_PASSWORD=postgres
