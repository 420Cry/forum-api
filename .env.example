# Base env file (host-native dev, staging overrides, etc.)
# For `forum dev`, copy .env.local.example → .env.local and run `forum env:sync`.

PORT=3001
NODE_ENV=development

# Comma-separated allowed browser origins
CORS_ORIGIN=

# Supabase Auth - server-side token verification
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres (Supabase local or remote)
DB_HOST=127.0.0.1
DB_PORT=54322
DB_NAME=postgres
DB_USERNAME=postgres
DB_PASSWORD=postgres
